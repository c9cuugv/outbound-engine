# ─── Database (auto-configured for Docker) ───
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/outbound
REDIS_URL=redis://redis:6379/0

# ─── Authentication ───
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ───
ALLOWED_ORIGINS=http://localhost:3000

# ─── AI Providers (set at least one) ───
# Option 1: NVIDIA NIM (recommended)
NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Option 2: Google Gemini
GEMINI_API_KEY=

# Option 3: Groq
GROQ_API_KEY=

# Option 4: Anthropic Claude
ANTHROPIC_API_KEY=

# ─── AI Provider Selection ───
# Options: nvidia, gemini, groq, anthropic
RESEARCH_PROVIDER=nvidia
EMAIL_GEN_PROVIDER=nvidia
SENTIMENT_PROVIDER=nvidia

# ─── Email Sending ───
# Options: console (prints to logs), resend, sendgrid
EMAIL_PROVIDER=console
RESEND_API_KEY=
SENDGRID_API_KEY=

# ─── Tracking ───
# Domain used in tracking pixel/click URLs (e.g. https://track.yourdomain.com)
TRACKING_DOMAIN=

# ─── Reply Detection (IMAP) ───
IMAP_HOST=
IMAP_EMAIL=
IMAP_PASSWORD=
