# ─── Database ───
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/outbound
REDIS_URL=redis://:changeme-redis@localhost:6379/0

# ─── Authentication ───
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=your_secure_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ───
ALLOWED_ORIGINS=http://localhost:3000

# ─── AI Providers ───
# Get a free API key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Choose provider (gemini, groq, anthropic)
RESEARCH_PROVIDER=gemini
EMAIL_GEN_PROVIDER=gemini
SENTIMENT_PROVIDER=gemini

# ─── Email Sending ───
# "console" for logging only, "resend" or "sendgrid" for actual emails
EMAIL_PROVIDER=console
RESEND_API_KEY=
SENDGRID_API_KEY=

# ─── Tracking ───
TRACKING_DOMAIN=http://localhost:8000

# ─── Reply Detection (IMAP) ───
IMAP_HOST=imap.gmail.com
IMAP_EMAIL=your_email@gmail.com
IMAP_PASSWORD=your_app_password
